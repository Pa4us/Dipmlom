<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Общежитие ГГТУ</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/css/tom-select.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="d-flex">

    <!-- ── Sidebar ──────────────────────────────────── -->
    <nav class="sidebar" id="sidebar">
        <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
            <i class="bi bi-building-fill"></i> Общежитие ГГТУ
        </a>

        <ul class="nav flex-column mt-2 sidebar-nav px-1">
            @if (User.IsInRole("Manager"))
            {
                <li class="sidebar-section-title">Заведующая</li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Manager" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
                       asp-controller="Manager" asp-action="Dashboard">
                        <i class="bi bi-speedometer2"></i> Дашборд
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Manager" && ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")"
                       asp-controller="Manager" asp-action="Users">
                        <i class="bi bi-people-fill"></i> Аккаунты
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Manager" && ViewContext.RouteData.Values["action"]?.ToString() == "Blocks" ? "active" : "")"
                       asp-controller="Manager" asp-action="Blocks">
                        <i class="bi bi-building"></i> Блоки
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Manager" && ViewContext.RouteData.Values["action"]?.ToString() == "Rooms" ? "active" : "")"
                       asp-controller="Manager" asp-action="Rooms">
                        <i class="bi bi-door-open"></i> Комнаты
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Manager" && ViewContext.RouteData.Values["action"]?.ToString() == "Residences" ? "active" : "")"
                       asp-controller="Manager" asp-action="Residences">
                        <i class="bi bi-house"></i> Проживание
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Manager" && ViewContext.RouteData.Values["action"]?.ToString() == "RepairRequests" ? "active" : "")"
                       asp-controller="Manager" asp-action="RepairRequests">
                        <i class="bi bi-tools"></i> Заявки на ремонт
                    </a>
                </li>
            }

            @if (User.IsInRole("Educator"))
            {
                <li class="sidebar-section-title">Воспитатель</li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["controller"]?.ToString() == "Educator" ? "active" : "")"
                       asp-controller="Educator" asp-action="Dashboard">
                        <i class="bi bi-speedometer2"></i> Дашборд
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Educator" && ViewContext.RouteData.Values["action"]?.ToString() == "Inspections" ? "active" : "")"
                       asp-controller="Educator" asp-action="Inspections">
                        <i class="bi bi-clipboard-check"></i> Результаты проверок
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Students" ? "active" : "")"
                       asp-controller="Educator" asp-action="Students">
                        <i class="bi bi-people"></i> Студенты
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Points" && ViewContext.RouteData.Values["controller"]?.ToString() == "Educator" ? "active" : "")"
                       asp-controller="Educator" asp-action="Points">
                        <i class="bi bi-star"></i> Баллы студентов
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Events" ? "active" : "")"
                       asp-controller="Educator" asp-action="Events">
                        <i class="bi bi-calendar-event"></i> Мероприятия
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Schedule" ? "active" : "")"
                       asp-controller="Educator" asp-action="Schedule">
                        <i class="bi bi-calendar-week"></i> Расписание проверок
                    </a>
                </li>
            }

            @if (User.IsInRole("Student"))
            {
                <li class="sidebar-section-title">Студент</li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
                       asp-controller="Student" asp-action="Dashboard">
                        <i class="bi bi-house"></i> Моя страница
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "RepairRequests" ? "active" : "")"
                       asp-controller="Student" asp-action="RepairRequests">
                        <i class="bi bi-tools"></i> Заявки на ремонт
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Events" && ViewContext.RouteData.Values["controller"]?.ToString() == "Student" ? "active" : "")"
                       asp-controller="Student" asp-action="Events">
                        <i class="bi bi-calendar-event"></i> Мероприятия
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Points" && ViewContext.RouteData.Values["controller"]?.ToString() == "Student" ? "active" : "")"
                       asp-controller="Student" asp-action="Points">
                        <i class="bi bi-star"></i> Мои баллы
                    </a>
                </li>
            }

            @if (User.IsInRole("Mechanic"))
            {
                <li class="sidebar-section-title">Слесарь</li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
                       asp-controller="Mechanic" asp-action="Dashboard">
                        <i class="bi bi-tools"></i> Заявки на ремонт
                    </a>
                </li>
            }

            @if (User.IsInRole("Inspector"))
            {
                <li class="sidebar-section-title">Инспектор</li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inspector" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
                       asp-controller="Inspector" asp-action="Dashboard">
                        <i class="bi bi-house"></i> Моя страница
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inspector" && ViewContext.RouteData.Values["action"]?.ToString() == "RepairRequests" ? "active" : "")"
                       asp-controller="Inspector" asp-action="RepairRequests">
                        <i class="bi bi-tools"></i> Заявки на ремонт
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inspector" && ViewContext.RouteData.Values["action"]?.ToString() == "Events" ? "active" : "")"
                       asp-controller="Inspector" asp-action="Events">
                        <i class="bi bi-calendar-event"></i> Мероприятия
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inspector" && ViewContext.RouteData.Values["action"]?.ToString() == "Points" ? "active" : "")"
                       asp-controller="Inspector" asp-action="Points">
                        <i class="bi bi-star"></i> Мои баллы
                    </a>
                </li>
            }
        </ul>

        <!-- Пользователь + кнопка выхода -->
        <div class="sidebar-footer">
            <div class="user-info">
                <i class="bi bi-person-circle"></i>
                <div>
                    <div class="fw-semibold text-white" style="font-size:.85rem">
                        @User.FindFirst("FullName")?.Value
                    </div>
                    <div style="font-size:.75rem;color:rgba(255,255,255,.45)">
                        @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                    </div>
                </div>
            </div>
            <a asp-controller="Auth" asp-action="Logout"
               class="btn btn-sm btn-outline-light w-100 mt-2">
                <i class="bi bi-box-arrow-right me-1"></i> Выйти
            </a>
        </div>
    </nav>

    <!-- ── Основной контент ──────────────────────────── -->
    <div class="main-content flex-grow-1">
        <!-- Top bar -->
        <div class="topbar">
            <button class="btn btn-link text-secondary p-0 d-md-none" id="sidebar-toggle">
                <i class="bi bi-list fs-5"></i>
            </button>
            <span class="fw-semibold text-dark">@ViewData["Title"]</span>
            <span class="text-muted" style="font-size:.85rem">
                <i class="bi bi-calendar3 me-1"></i>@DateTime.Today.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ru-RU"))
            </span>
        </div>

        <!-- Alerts -->
        <div class="content-area">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <div>@TempData["Success"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div>@TempData["Error"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/js/tom-select.complete.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    // Sidebar toggle для мобильных
    document.getElementById('sidebar-toggle')?.addEventListener('click', () => {
        document.getElementById('sidebar')?.classList.toggle('open');
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
