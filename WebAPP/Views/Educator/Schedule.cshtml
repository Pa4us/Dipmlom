@model InspectionScheduleViewModel
@{ ViewData["Title"] = "Расписание проверок"; }

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="form-card">
            <h6 class="fw-bold mb-1">
                <i class="bi bi-calendar-week-fill text-primary me-2"></i>Дни проведения проверок
            </h6>
            <p class="text-muted small mb-4">
                Выберите дни недели, когда инспекторам разрешено проводить проверки блоков.
                В остальные дни форма проверки будет недоступна.
            </p>

            <form method="post">
                <div class="row g-3 mb-4">
                    @{
                        var dayNames = new[] { "Понедельник", "Вторник", "Среда", "Четверг", "Пятница", "Суббота", "Воскресенье" };
                        var dayIcons = new[] { "bi-1-circle", "bi-2-circle", "bi-3-circle", "bi-4-circle", "bi-5-circle", "bi-6-circle", "bi-7-circle" };
                    }
                    @for (int d = 0; d < 7; d++)
                    {
                        var isEnabled = Model.EnabledDays.Contains(d);
                        var isWeekend = d >= 5;
                        <div class="col-6">
                            <div class="form-check form-check-card @(isEnabled ? "checked" : "") @(isWeekend ? "weekend" : "")"
                                 onclick="this.querySelector('input').click(); this.classList.toggle('checked')">
                                <input class="form-check-input" type="checkbox"
                                       name="enabledDays" value="@d" id="day@d"
                                       @(isEnabled ? "checked" : "") />
                                <label class="form-check-label d-flex align-items-center gap-2 w-100" for="day@d">
                                    <i class="bi @dayIcons[d] @(isWeekend ? "text-danger" : "text-primary")"></i>
                                    <span class="fw-semibold">@dayNames[d]</span>
                                    @if (isWeekend) { <span class="badge bg-danger ms-auto">вых.</span> }
                                </label>
                            </div>
                        </div>
                    }
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-save me-1"></i>Сохранить расписание
                </button>
            </form>
        </div>

        <!-- Текущий статус -->
        <div class="card stat-card mt-3">
            <div class="card-body">
                <div class="fw-semibold mb-2">
                    <i class="bi bi-info-circle me-1 text-info"></i>Текущий статус
                </div>
                @{
                    var today = (int)DateTime.Today.DayOfWeek;
                    var normalizedToday = today == 0 ? 6 : today - 1;
                    var isAllowed = Model.EnabledDays.Contains(normalizedToday);
                    var todayName = new[] { "Понедельник", "Вторник", "Среда", "Четверг", "Пятница", "Суббота", "Воскресенье" }[normalizedToday];
                }
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted">Сегодня (@todayName):</span>
                    @if (isAllowed)
                    {
                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Проверки разрешены</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary"><i class="bi bi-lock me-1"></i>Проверки не проводятся</span>
                    }
                </div>
                @if (Model.EnabledDays.Any())
                {
                    var enabledNames = Model.EnabledDays.OrderBy(d => d)
                        .Select(d => new[] { "Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс" }[d]);
                    <div class="small text-muted mt-1">
                        Разрешённые дни: <strong>@string.Join(", ", enabledNames)</strong>
                    </div>
                }
                else
                {
                    <div class="small text-danger mt-1">Проверки не разрешены ни в один день</div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .form-check-card {
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        padding: 12px 14px;
        cursor: pointer;
        transition: all .2s;
        user-select: none;
    }
    .form-check-card:hover { border-color: #6366f1; background: #f8f7ff; }
    .form-check-card.checked { border-color: #6366f1; background: #eef2ff; }
    .form-check-card.weekend .form-check-label { color: #dc2626; }
    .form-check-card input { pointer-events: none; }
</style>
