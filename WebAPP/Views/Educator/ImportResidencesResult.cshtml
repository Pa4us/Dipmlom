@model ImportResidencesResultViewModel
@{ ViewData["Title"] = "Заселение завершено"; }

<div class="text-center py-4 mb-4">
    <i class="bi bi-house-check-fill text-success" style="font-size:3rem"></i>
    <h4 class="mt-3 fw-bold">Готово!</h4>
    <p class="text-muted">Заселено студентов: <strong class="text-success">@Model.Result.CreatedCount</strong></p>
</div>

@if (Model.Result.ValidRows.Any())
{
    <div class="table-card mb-4">
        <div class="p-3 border-bottom fw-semibold">
            <i class="bi bi-house-fill text-success me-2"></i>Заселённые студенты
        </div>
        <div class="table-responsive">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr><th>Логин</th><th>ФИО</th><th>Блок</th><th>Комната</th></tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Result.ValidRows)
                    {
                        <tr>
                            <td><code>@r.Username</code></td>
                            <td>@(r.FullName ?? "—")</td>
                            <td><span class="badge bg-secondary">@r.BlockNumber</span></td>
                            <td class="fw-semibold text-success">@r.AssignedRoom</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="d-flex gap-2">
    <a asp-action="ImportResidences" class="btn btn-primary">
        <i class="bi bi-file-earmark-arrow-up me-1"></i>Импортировать ещё
    </a>
    <a asp-action="Students" class="btn btn-outline-secondary">
        <i class="bi bi-people me-1"></i>К списку студентов
    </a>
</div>
