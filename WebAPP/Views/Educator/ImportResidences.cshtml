@{ ViewData["Title"] = "Импорт заселения"; }

<div class="row justify-content-center">
    <div class="col-lg-7">

        <div class="form-card">
            <h6 class="fw-bold mb-1"><i class="bi bi-file-earmark-arrow-up text-primary me-2"></i>Загрузить файл заселения</h6>
            <p class="text-muted small mb-4">
                Загрузите Excel-файл (.xlsx) со списком студентов и их блоками. Перед применением
                будет показан превью с результатом проверки.
            </p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }

            <form method="post" enctype="multipart/form-data" asp-action="ImportResidences">
                <div class="mb-4">
                    <label class="form-label fw-semibold">Файл Excel <span class="text-danger">*</span></label>
                    <input type="file" name="file" accept=".xlsx" class="form-control" required />
                    <div class="form-text">Обязательные колонки: <strong>Логин, Блок</strong>. Необязательная: <strong>ФИО</strong>. Блок указывается в формате <strong>41-1</strong> (номер блока — номер комнаты)</div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search me-1"></i>Проверить файл
                    </button>
                    <a asp-action="ImportResidencesTemplate" class="btn btn-outline-success">
                        <i class="bi bi-file-earmark-excel me-1"></i>Скачать шаблон
                    </a>
                </div>
            </form>
        </div>

        <div class="form-card mt-4">
            <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>Формат файла</h6>
            <div class="table-responsive">
                <table class="table table-sm table-bordered mb-2">
                    <thead class="table-light">
                        <tr><th>Логин</th><th>ФИО</th><th>Блок</th></tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>ivanov</td>
                            <td class="text-muted">Иванов Иван Иванович</td>
                            <td>41-1</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <ul class="small text-muted mb-0">
                <li>Аккаунты студентов должны быть уже созданы (сначала импортирует Заведующая)</li>
                <li>Колонка <strong>Блок</strong> обязательно должна содержать номер комнаты через тире: <strong>41-1</strong> или <strong>41-2</strong> — формат без комнаты (например, просто <strong>41</strong>) не допускается</li>
                <li>Студенты, уже имеющие активное заселение, будут помечены как ошибка</li>
            </ul>
        </div>

    </div>
</div>
