@model EducatorDashboardViewModel
@{ ViewData["Title"] = "Дашборд"; }

@functions {
    static string ScoreClass(decimal s) => s >= 8 ? "score-high" : s >= 5 ? "score-medium" : "score-low";
    static string ScoreBg(decimal s)    => s >= 8 ? "#27ae60" : s >= 5 ? "#f39c12" : "#e74c3c";
}

<!-- Статистические карточки -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-start border-4 border-primary">
            <div class="card-body">
                <div class="stat-number text-primary">@Model.Stats.AverageScore.ToString("F1")</div>
                <div class="stat-label">Средний балл общежития</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-start border-4 border-success">
            <div class="card-body">
                <div class="stat-number text-success">@Model.Stats.TotalBlocks</div>
                <div class="stat-label">Всего блоков</div>
            </div>
        </div>
    </div>
    @foreach (var floor in Model.Stats.Floors)
    {
        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card border-start border-4 border-warning">
                <div class="card-body">
                    <div class="stat-number text-warning">@floor.AverageScore.ToString("F1")</div>
                    <div class="stat-label">Средний балл — @floor.Floor этаж</div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-4 mb-4">
    <!-- График баллов по блокам -->
    <div class="col-lg-7">
        <div class="card stat-card h-100">
            <div class="card-header bg-white fw-semibold border-0 pt-3">
                <i class="bi bi-bar-chart-fill text-primary me-2"></i>Текущие оценки блоков
            </div>
            <div class="card-body">
                <canvas id="blocksChart" height="200"></canvas>
            </div>
        </div>
    </div>

    <!-- Лучшие и худшие -->
    <div class="col-lg-5">
        <div class="card stat-card mb-3">
            <div class="card-header bg-white fw-semibold border-0 pt-3 text-success">
                <i class="bi bi-trophy-fill me-2"></i>Лучшие блоки
            </div>
            <ul class="list-group list-group-flush">
                @foreach (var b in Model.BestBlocks)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Блок @b.BlockNumber</span>
                        <span class="score-badge @ScoreClass(b.Score)">@b.Score.ToString("F1")</span>
                    </li>
                }
                @if (!Model.BestBlocks.Any())
                {
                    <li class="list-group-item text-muted small">Нет данных за текущую неделю</li>
                }
            </ul>
        </div>
        <div class="card stat-card">
            <div class="card-header bg-white fw-semibold border-0 pt-3 text-danger">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>Требуют внимания
            </div>
            <ul class="list-group list-group-flush">
                @foreach (var b in Model.WorstBlocks)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Блок @b.BlockNumber</span>
                        <span class="score-badge @ScoreClass(b.Score)">@b.Score.ToString("F1")</span>
                    </li>
                }
                @if (!Model.WorstBlocks.Any())
                {
                    <li class="list-group-item text-muted small">Нет данных</li>
                }
            </ul>
        </div>
    </div>
</div>

<!-- Последние проверки -->
<div class="table-card">
    <div class="p-3 border-bottom fw-semibold d-flex justify-content-between align-items-center">
        <span><i class="bi bi-clipboard-check me-2 text-primary"></i>Последние проверки</span>
        <a asp-controller="Educator" asp-action="Inspections" class="btn btn-sm btn-outline-primary">
            Все проверки <i class="bi bi-arrow-right ms-1"></i>
        </a>
    </div>
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Блок</th>
                <th>Зона</th>
                <th>Инспектор</th>
                <th>Оценка</th>
                <th>Комментарий</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var i in Model.RecentInspections)
            {
                <tr>
                    <td>@i.InspectionDate.ToString("dd.MM.yyyy")</td>
                    <td><span class="badge bg-secondary">@i.BlockNumber</span></td>
                    <td>@i.ZoneName</td>
                    <td>@i.InspectorName</td>
                    <td><span class="score-badge @ScoreClass(i.Score)">@i.Score / 10</span></td>
                    <td class="text-muted small">@i.Comment</td>
                </tr>
            }
            @if (!Model.RecentInspections.Any())
            {
                <tr><td colspan="6" class="text-center text-muted py-3">Нет данных</td></tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
    const allScores = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Stats.Floors.SelectMany(f => f.BlockScores)
            .Select(b => new { label = "Блок " + b.BlockNumber, score = (double)b.Score })
            .ToList()));

    if (allScores.length > 0) {
        new Chart(document.getElementById('blocksChart'), {
            type: 'bar',
            data: {
                labels: allScores.map(x => x.label),
                datasets: [{
                    label: 'Оценка',
                    data: allScores.map(x => x.score),
                    backgroundColor: allScores.map(x => x.score >= 8 ? '#27ae60' : x.score >= 5 ? '#f39c12' : '#e74c3c'),
                    borderRadius: 6,
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { min: 0, max: 10, grid: { color: '#f0f0f0' } },
                    x: { grid: { display: false } }
                }
            }
        });
    } else {
        document.getElementById('blocksChart').insertAdjacentHTML('beforebegin',
            '<p class="text-center text-muted py-4">Нет данных за текущую неделю. ' +
            '<a href="/api/statistics/recalculate-all" class="link-primary">Пересчитать</a></p>');
        document.getElementById('blocksChart').style.display = 'none';
    }
</script>
}
