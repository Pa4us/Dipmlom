@model ManagerDashboardViewModel
@{ ViewData["Title"] = "Панель заведующей"; }

<!-- Статистика -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-2">
        <div class="card stat-card text-center h-100">
            <div class="card-body py-3">
                <div class="display-6 fw-bold text-primary">@Model.TotalUsers</div>
                <div class="small text-muted mt-1">Всего аккаунтов</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="card stat-card text-center h-100">
            <div class="card-body py-3">
                <div class="display-6 fw-bold text-info">@Model.TotalStudents</div>
                <div class="small text-muted mt-1">Студентов</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="card stat-card text-center h-100">
            <div class="card-body py-3">
                <div class="display-6 fw-bold text-secondary">@Model.TotalBlocks</div>
                <div class="small text-muted mt-1">Блоков</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="card stat-card text-center h-100">
            <div class="card-body py-3">
                <div class="display-6 fw-bold text-dark">@Model.TotalRooms</div>
                <div class="small text-muted mt-1">Комнат</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="card stat-card text-center h-100">
            <div class="card-body py-3">
                <div class="display-6 fw-bold text-success">@Model.FreeRooms</div>
                <div class="small text-muted mt-1">Свободных комнат</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="card stat-card text-center h-100">
            <div class="card-body py-3">
                <div class="display-6 fw-bold text-warning">@Model.CurrentResidents</div>
                <div class="small text-muted mt-1">Проживают сейчас</div>
            </div>
        </div>
    </div>
</div>

<!-- Быстрые ссылки -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <a asp-action="Users" class="card stat-card text-decoration-none h-100 d-block">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-people-fill text-primary fs-4"></i>
                </div>
                <div>
                    <div class="fw-bold">Аккаунты</div>
                    <div class="small text-muted">Создать, редактировать</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-action="Blocks" class="card stat-card text-decoration-none h-100 d-block">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-secondary bg-opacity-10 p-3">
                    <i class="bi bi-building-fill text-secondary fs-4"></i>
                </div>
                <div>
                    <div class="fw-bold">Блоки</div>
                    <div class="small text-muted">Справочник блоков</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-action="Rooms" class="card stat-card text-decoration-none h-100 d-block">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-info bg-opacity-10 p-3">
                    <i class="bi bi-door-open-fill text-info fs-4"></i>
                </div>
                <div>
                    <div class="fw-bold">Комнаты</div>
                    <div class="small text-muted">Справочник комнат</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-action="Residences" class="card stat-card text-decoration-none h-100 d-block">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-house-fill text-success fs-4"></i>
                </div>
                <div>
                    <div class="fw-bold">Проживание</div>
                    <div class="small text-muted">Заселение / выселение</div>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- Последние аккаунты -->
@if (Model.RecentUsers.Any())
{
    <div class="table-card">
        <div class="p-3 border-bottom fw-semibold">
            <i class="bi bi-clock-history me-2 text-secondary"></i>Последние зарегистрированные аккаунты
        </div>
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>ФИО</th>
                    <th>Логин</th>
                    <th>Email</th>
                    <th>Роль</th>
                    <th>Статус</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.RecentUsers)
                {
                    <tr>
                        <td class="fw-semibold">@u.FullName</td>
                        <td><code>@u.Username</code></td>
                        <td class="small text-muted">@u.Email</td>
                        <td><span class="badge bg-light text-dark border">@u.RoleName</span></td>
                        <td>
                            @if (u.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle">Активен</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Заблокирован</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
