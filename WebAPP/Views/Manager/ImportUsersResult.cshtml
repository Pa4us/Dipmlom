@model ImportUsersResultViewModel
@{ ViewData["Title"] = "Импорт завершён"; }

<div class="text-center py-4 mb-4">
    <i class="bi bi-check-circle-fill text-success" style="font-size:3rem"></i>
    <h4 class="mt-3 fw-bold">Готово!</h4>
    <p class="text-muted">Создано аккаунтов: <strong class="text-success">@Model.Result.CreatedCount</strong></p>
</div>

<!-- Скачать пароли -->
@if (!string.IsNullOrEmpty(Model.PasswordReportBase64))
{
    <div class="alert alert-warning d-flex align-items-center gap-3 mb-4">
        <i class="bi bi-key-fill fs-3 text-warning"></i>
        <div class="flex-grow-1">
            <div class="fw-semibold">Сохраните файл с паролями!</div>
            <div class="small text-muted">Пароли генерируются один раз — восстановить их позже нельзя</div>
        </div>
        <a href="data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,@Model.PasswordReportBase64"
           download="Пароли_@(DateTime.Today.ToString("yyyyMMdd")).xlsx"
           class="btn btn-warning text-dark flex-shrink-0">
            <i class="bi bi-file-earmark-excel me-1"></i>Скачать пароли
        </a>
    </div>
}

<!-- Список созданных -->
@if (Model.Result.ValidRows.Any())
{
    <div class="table-card mb-4">
        <div class="p-3 border-bottom fw-semibold">
            <i class="bi bi-people-fill text-success me-2"></i>Созданные аккаунты
        </div>
        <div class="table-responsive">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr><th>ФИО</th><th>Логин</th><th>Email</th><th>Роль</th></tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Result.ValidRows)
                    {
                        <tr>
                            <td>@r.FullName</td>
                            <td><code>@r.Username</code></td>
                            <td class="text-muted small">@r.Email</td>
                            <td><span class="badge bg-secondary">@r.RoleName</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="d-flex gap-2">
    <a asp-action="ImportUsers" class="btn btn-primary">
        <i class="bi bi-file-earmark-arrow-up me-1"></i>Импортировать ещё
    </a>
    <a asp-action="Users" class="btn btn-outline-secondary">
        <i class="bi bi-people me-1"></i>К списку аккаунтов
    </a>
</div>
