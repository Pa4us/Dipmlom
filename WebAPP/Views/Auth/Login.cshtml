@model LoginDto
@{ Layout = "_LayoutLogin"; ViewData["Title"] = "Вход"; }

<div class="login-wrapper">
    <div class="login-card card p-4 p-md-5">
        <div class="text-center mb-4">
            <i class="bi bi-building-fill text-primary" style="font-size:2.5rem"></i>
            <h4 class="mt-2 fw-bold">Общежитие ГГТУ</h4>
            <p class="text-muted small">Система управления общежитием</p>
        </div>

        @if (TempData["ResetSuccess"] != null)
        {
            <div class="alert alert-success d-flex align-items-center py-2 mb-3">
                <i class="bi bi-check-circle me-2"></i>
                <div class="small">@TempData["ResetSuccess"]</div>
            </div>
        }

        <form method="post" asp-action="Login">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger d-flex align-items-center py-2">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <div asp-validation-summary="All" class="mb-0 small"></div>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Login" class="form-label fw-semibold">Логин или Email</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-person text-secondary"></i></span>
                    <input asp-for="Login" class="form-control" placeholder="Введите логин или email" autocomplete="username" />
                </div>
            </div>

            <div class="mb-2">
                <label asp-for="Password" class="form-label fw-semibold">Пароль</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-lock text-secondary"></i></span>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Введите пароль" autocomplete="current-password" />
                </div>
            </div>

            <div class="text-end mb-4">
                <a asp-action="ForgotPassword" class="small text-muted text-decoration-none">
                    <i class="bi bi-question-circle me-1"></i>Забыли пароль?
                </a>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                <i class="bi bi-box-arrow-in-right me-2"></i>Войти
            </button>
        </form>

        <div class="text-center mt-4 text-muted small">
            ГГТУ им. П. О. Сухого © @DateTime.Today.Year
        </div>
    </div>
</div>
