@{ Layout = "_LayoutLogin"; ViewData["Title"] = "Восстановление пароля"; }

<div class="login-wrapper">
    <div class="login-card card p-4 p-md-5">
        <div class="text-center mb-4">
            <i class="bi bi-envelope-open-fill text-primary" style="font-size:2.5rem"></i>
            <h4 class="mt-2 fw-bold">Восстановление пароля</h4>
            <p class="text-muted small">Общежитие ГГТУ им. П. О. Сухого</p>
        </div>

        @if (ViewBag.Sent == true)
        {
            <div class="alert alert-success d-flex align-items-start gap-2">
                <i class="bi bi-check-circle-fill flex-shrink-0 mt-1"></i>
                <div>
                    <div class="fw-semibold">Письмо отправлено</div>
                    <div class="small mt-1">
                        Если указанный email зарегистрирован в системе, вы получите письмо
                        со ссылкой для сброса пароля. Ссылка действительна <strong>30 минут</strong>.
                    </div>
                </div>
            </div>
            <a asp-action="Login" class="btn btn-outline-primary w-100">
                <i class="bi bi-arrow-left me-2"></i>Вернуться к входу
            </a>
        }
        else
        {
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger d-flex align-items-center py-2">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <div asp-validation-summary="All" class="mb-0 small"></div>
                </div>
            }

            <p class="text-muted small mb-4">
                Введите email, указанный при регистрации. Мы отправим ссылку для сброса пароля.
            </p>

            <form method="post" asp-action="ForgotPassword">
                <div class="mb-4">
                    <label class="form-label fw-semibold">Email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-envelope text-secondary"></i></span>
                        <input type="email" name="email" class="form-control"
                               placeholder="example@ggtu.by" autocomplete="email" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                    <i class="bi bi-send me-2"></i>Отправить инструкции
                </button>
            </form>

            <div class="text-center mt-3">
                <a asp-action="Login" class="small text-muted text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i>Вернуться к входу
                </a>
            </div>
        }
    </div>
</div>
