@model StudentEventsViewModel
@{ ViewData["Title"] = "Мероприятия"; }

@if (!Model.UpcomingEvents.Any() && !Model.PastEvents.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-calendar-x" style="font-size:3rem"></i>
        <p class="mt-2">Мероприятий пока нет</p>
    </div>
}

<!-- Предстоящие мероприятия -->
@if (Model.UpcomingEvents.Any())
{
    <h6 class="fw-bold text-primary mb-3">
        <i class="bi bi-calendar-event me-2"></i>Предстоящие мероприятия
    </h6>
    <div class="row g-3 mb-4">
        @foreach (var ev in Model.UpcomingEvents)
        {
            var daysLeft = (ev.EventDate.ToDateTime(TimeOnly.MinValue) - DateTime.Today).Days;
            var urgencyClass = daysLeft <= 3 ? "border-danger" : daysLeft <= 7 ? "border-warning" : "border-primary";
            var urgencyText  = daysLeft == 0 ? "Сегодня!" : daysLeft == 1 ? "Завтра" : $"Через {daysLeft} дн.";
            var urgencyBadge = daysLeft <= 3 ? "bg-danger" : daysLeft <= 7 ? "bg-warning text-dark" : "bg-primary";

            <div class="col-md-6 col-xl-4">
                <div class="card stat-card h-100 border-start border-3 @urgencyClass">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="fw-bold mb-0 me-2">@ev.Title</h6>
                            <span class="badge @urgencyBadge text-nowrap flex-shrink-0">@urgencyText</span>
                        </div>
                        @if (!string.IsNullOrEmpty(ev.Description))
                        {
                            <p class="text-muted small mb-3">@ev.Description</p>
                        }
                        <div class="d-flex flex-wrap gap-2 small text-muted">
                            <span><i class="bi bi-calendar3 me-1"></i>@ev.EventDate.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ru-RU"))</span>
                            @if (!string.IsNullOrEmpty(ev.Location))
                            {
                                <span><i class="bi bi-geo-alt me-1"></i>@ev.Location</span>
                            }
                            <span class="text-warning fw-semibold">
                                <i class="bi bi-star-fill me-1"></i>@ev.PointsAwarded баллов
                            </span>
                            @if (ev.ParticipantsCount > 0)
                            {
                                <span><i class="bi bi-people me-1"></i>@ev.ParticipantsCount участников</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Прошедшие мероприятия -->
@if (Model.PastEvents.Any())
{
    <h6 class="fw-bold text-muted mb-3">
        <i class="bi bi-clock-history me-2"></i>Прошедшие мероприятия
    </h6>
    <div class="table-card">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Название</th>
                    <th>Дата</th>
                    <th>Место</th>
                    <th class="text-center">Баллы</th>
                    <th class="text-center">Участников</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ev in Model.PastEvents)
                {
                    <tr class="text-muted">
                        <td>
                            <span class="fw-semibold text-dark">@ev.Title</span>
                            @if (!string.IsNullOrEmpty(ev.Description))
                            {
                                <div class="small text-muted">@ev.Description</div>
                            }
                        </td>
                        <td class="small">@ev.EventDate.ToString("dd.MM.yyyy")</td>
                        <td class="small">@(ev.Location ?? "—")</td>
                        <td class="text-center">
                            <span class="badge bg-warning text-dark">+@ev.PointsAwarded</span>
                        </td>
                        <td class="text-center small">@ev.ParticipantsCount</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
