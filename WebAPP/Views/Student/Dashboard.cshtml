@model StudentDashboardViewModel
@{ ViewData["Title"] = "Моя страница"; }

@functions {
    static string ScoreClass(int s) => s >= 8 ? "score-high" : s >= 5 ? "score-medium" : "score-low";
}

<div class="row g-4">

    <!-- Карточка проживания -->
    <div class="col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                        <i class="bi bi-house-fill text-primary fs-4"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">Моё проживание</h6>
                        <span class="text-muted small">Текущий статус</span>
                    </div>
                </div>
                @if (Model.Residence != null)
                {
                    <dl class="row mb-0 small">
                        <dt class="col-6 text-muted">Блок</dt>
                        <dd class="col-6 fw-semibold">@Model.Residence.BlockNumber</dd>
                        <dt class="col-6 text-muted">Комната</dt>
                        <dd class="col-6 fw-semibold">@Model.Residence.RoomNumber</dd>
                        <dt class="col-6 text-muted">Этаж</dt>
                        <dd class="col-6 fw-semibold">@Model.Residence.Floor</dd>
                        <dt class="col-6 text-muted">Заселён</dt>
                        <dd class="col-6 fw-semibold">@Model.Residence.MoveInDate.ToString("dd.MM.yyyy")</dd>
                        <dt class="col-6 text-muted">Дней</dt>
                        <dd class="col-6 fw-semibold">@Model.Residence.DurationDays</dd>
                    </dl>
                }
                else
                {
                    <p class="text-muted small mb-0">Данные о проживании не найдены</p>
                }
            </div>
        </div>
    </div>

    <!-- Последняя проверка блока -->
    <div class="col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle bg-info bg-opacity-10 p-3">
                        <i class="bi bi-clipboard-check-fill text-info fs-4"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">Последняя проверка</h6>
                        <span class="text-muted small">Моего блока</span>
                    </div>
                </div>
                @if (Model.LatestBlockInspection != null)
                {
                    var i = Model.LatestBlockInspection;
                    <div class="text-center mb-3">
                        <div class="display-4 fw-bold @(i.Score >= 8 ? "text-success" : i.Score >= 5 ? "text-warning" : "text-danger")">
                            @i.Score
                        </div>
                        <div class="text-muted small">из 10 баллов</div>
                    </div>
                    <dl class="row mb-0 small">
                        <dt class="col-6 text-muted">Дата</dt>
                        <dd class="col-6">@i.InspectionDate.ToString("dd.MM.yyyy")</dd>
                        <dt class="col-6 text-muted">Зона</dt>
                        <dd class="col-6">@i.ZoneName</dd>
                        @if (!string.IsNullOrEmpty(i.Comment))
                        {
                            <dt class="col-6 text-muted">Комментарий</dt>
                            <dd class="col-6">@i.Comment</dd>
                        }
                    </dl>
                }
                else
                {
                    <p class="text-muted small mb-0">Проверок ещё не было</p>
                }
            </div>
        </div>
    </div>

    <!-- Мои баллы -->
    <div class="col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                        <i class="bi bi-star-fill text-warning fs-4"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">Мои баллы</h6>
                        <span class="text-muted small">Рейтинг общежития</span>
                    </div>
                </div>
                @if (Model.Rating != null)
                {
                    <div class="text-center mb-3">
                        <div class="display-4 fw-bold @(Model.Rating.TotalPoints >= 0 ? "text-success" : "text-danger")">
                            @(Model.Rating.TotalPoints >= 0 ? "+" : "")@Model.Rating.TotalPoints
                        </div>
                        <div class="text-muted small">суммарных баллов</div>
                    </div>
                    <dl class="row mb-0 small">
                        <dt class="col-7 text-muted">За мероприятия</dt>
                        <dd class="col-5 text-success fw-semibold">+@Model.Rating.EventPoints</dd>
                        <dt class="col-7 text-muted">Взысканий</dt>
                        <dd class="col-5 text-danger fw-semibold">-@Model.Rating.PenaltyPoints</dd>
                    </dl>
                }
                else
                {
                    <p class="text-muted small mb-0">Баллов пока нет</p>
                }
                <a asp-controller="Student" asp-action="Points" class="btn btn-outline-warning btn-sm w-100 mt-3">
                    История баллов <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Ближайшие мероприятия -->
@if (Model.UpcomingEvents.Any())
{
    <div class="table-card mt-4">
        <div class="p-3 border-bottom fw-semibold d-flex justify-content-between align-items-center">
            <span><i class="bi bi-calendar-event me-2 text-primary"></i>Ближайшие мероприятия</span>
            <a asp-controller="Student" asp-action="Events" class="btn btn-sm btn-outline-primary">
                Все мероприятия <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
        <div class="row g-0">
            @foreach (var ev in Model.UpcomingEvents)
            {
                var daysLeft = (ev.EventDate.ToDateTime(TimeOnly.MinValue) - DateTime.Today).Days;
                var urgencyBadge = daysLeft <= 3 ? "bg-danger" : daysLeft <= 7 ? "bg-warning text-dark" : "bg-primary";
                var urgencyText  = daysLeft == 0 ? "Сегодня!" : daysLeft == 1 ? "Завтра" : $"Через {daysLeft} дн.";
                <div class="col-12 col-md-4 p-3 border-end border-bottom">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <span class="fw-semibold small">@ev.Title</span>
                        <span class="badge @urgencyBadge ms-2 flex-shrink-0">@urgencyText</span>
                    </div>
                    <div class="d-flex flex-wrap gap-2 small text-muted">
                        <span><i class="bi bi-calendar3 me-1"></i>@ev.EventDate.ToString("dd.MM.yyyy")</span>
                        @if (!string.IsNullOrEmpty(ev.Location))
                        {
                            <span><i class="bi bi-geo-alt me-1"></i>@ev.Location</span>
                        }
                        <span class="text-warning"><i class="bi bi-star-fill me-1"></i>@ev.PointsAwarded б.</span>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Последние заявки -->
@if (Model.MyRecentRequests.Any())
{
    <div class="table-card mt-4">
        <div class="p-3 border-bottom fw-semibold d-flex justify-content-between align-items-center">
            <span><i class="bi bi-tools me-2 text-secondary"></i>Мои последние заявки</span>
            <a asp-controller="Student" asp-action="RepairRequests" class="btn btn-sm btn-outline-secondary">
                Все заявки <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
        <table class="table mb-0">
            <tbody>
                @foreach (var r in Model.MyRecentRequests)
                {
                    var badgeClass = r.Status switch {
                        "InProgress" => "badge-inprogress", "Completed" => "badge-completed",
                        "Cancelled" => "badge-cancelled", _ => "badge-pending" };
                    var statusText = r.Status switch {
                        "Pending" => "Ожидает", "InProgress" => "В работе",
                        "Completed" => "Выполнено", "Cancelled" => "Отменено", _ => r.Status };
                    <tr>
                        <td>@r.Title</td>
                        <td class="text-muted small">@r.BlockNumber</td>
                        <td><span class="badge @badgeClass">@statusText</span></td>
                        <td class="text-muted small">@r.CreatedAt.ToString("dd.MM")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
