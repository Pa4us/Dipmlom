@model InspectorRepairRequestsViewModel
@{ ViewData["Title"] = "Заявки на ремонт"; }

<div class="row g-4">

    <!-- Список моих заявок -->
    <div class="col-lg-7">
        <div class="table-card">
            <div class="p-3 border-bottom fw-semibold">
                <i class="bi bi-tools me-2 text-primary"></i>Мои заявки
                <span class="badge bg-secondary ms-2">@Model.Requests.Count</span>
            </div>

            @if (!Model.Requests.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-check2-circle" style="font-size:2.5rem"></i>
                    <p class="mt-2 mb-0">Заявок нет — всё исправно!</p>
                </div>
            }

            @foreach (var r in Model.Requests)
            {
                var badgeClass = r.Status switch {
                    "InProgress" => "badge-inprogress", "Completed" => "badge-completed",
                    "Cancelled"  => "badge-cancelled",  _ => "badge-pending" };
                var statusText = r.Status switch {
                    "Pending"   => "Ожидает",  "InProgress" => "В работе",
                    "Completed" => "Выполнено","Cancelled"  => "Отменено", _ => r.Status };
                var priorityIcon = r.Priority == "High" ? "🔴" : r.Priority == "Normal" ? "🟡" : "⚪";
                var hasComments  = r.Comments != null && r.Comments.Any();

                <div class="border-bottom p-3">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <h6 class="fw-semibold mb-0">@priorityIcon @r.Title</h6>
                        <span class="badge @badgeClass ms-2">@statusText</span>
                    </div>
                    <p class="text-muted small mb-2">@r.Description</p>
                    <div class="d-flex flex-wrap gap-3 small text-muted mb-0">
                        <span><i class="bi bi-building me-1"></i>Блок @r.BlockNumber</span>
                        @if (!string.IsNullOrEmpty(r.RoomNumber))
                        {
                            <span><i class="bi bi-door-open me-1"></i>Комн. @r.RoomNumber</span>
                        }
                        <span><i class="bi bi-calendar3 me-1"></i>@r.CreatedAt.ToString("dd.MM.yyyy")</span>
                        @if (r.AssignedToName != null)
                        {
                            <span><i class="bi bi-person-wrench me-1"></i>@r.AssignedToName</span>
                        }
                        @if (r.CompletedAt.HasValue)
                        {
                            <span class="text-success"><i class="bi bi-check-circle me-1"></i>Выполнено @r.CompletedAt.Value.ToString("dd.MM")</span>
                        }
                    </div>

                    @if (hasComments)
                    {
                        <div class="mt-3 pt-2 border-top">
                            <div class="small fw-semibold text-muted mb-2">
                                <i class="bi bi-chat-left-text me-1"></i>Комментарии слесаря
                            </div>
                            <div class="d-flex flex-column gap-2">
                                @foreach (var c in r.Comments!)
                                {
                                    <div class="d-flex gap-2 align-items-start">
                                        <div class="rounded-circle bg-secondary bg-opacity-10 p-1 flex-shrink-0"
                                             style="width:28px;height:28px;display:flex;align-items:center;justify-content:center">
                                            <i class="bi bi-wrench text-secondary" style="font-size:.7rem"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="bg-light rounded px-3 py-2 small">
                                                <div class="fw-semibold text-dark mb-1" style="font-size:.75rem">
                                                    @c.UserName
                                                    <span class="text-muted fw-normal ms-2">@c.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                                                </div>
                                                <div>@c.Comment</div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Форма новой заявки -->
    <div class="col-lg-5">
        <div class="form-card">
            <h6 class="fw-bold mb-3">
                <i class="bi bi-plus-circle-fill text-primary me-2"></i>Подать новую заявку
            </h6>

            @if (Model.Residence == null)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Информация о проживании не найдена. Обратитесь к воспитателю.
                </div>
            }
            else
            {
                <form method="post" asp-action="CreateRepairRequest">
                    <input type="hidden" name="BlockId" value="@Model.Residence.BlockId" />
                    @if (Model.Residence.RoomId > 0)
                    {
                        <input type="hidden" name="RoomId" value="@Model.Residence.RoomId" />
                    }

                    <div class="alert alert-light border mb-3 py-2">
                        <div class="small text-muted">Ваше место проживания</div>
                        <div class="fw-semibold">
                            <i class="bi bi-building me-1 text-primary"></i>Блок @Model.Residence.BlockNumber
                            @if (!string.IsNullOrEmpty(Model.Residence.RoomNumber))
                            {
                                <span class="ms-2">
                                    <i class="bi bi-door-open me-1 text-primary"></i>Комната @Model.Residence.RoomNumber
                                </span>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Тема <span class="text-danger">*</span></label>
                        <input type="text" name="Title" class="form-control"
                               placeholder="Напр: Сломана ручка двери" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Описание <span class="text-danger">*</span></label>
                        <textarea name="Description" class="form-control" rows="3"
                                  placeholder="Подробно опишите проблему..." required></textarea>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Приоритет</label>
                        <select name="Priority" class="form-select">
                            <option value="Low">Низкий — терпит</option>
                            <option value="Normal" selected>Обычный</option>
                            <option value="High">Высокий — срочно</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-send me-1"></i>Отправить заявку
                    </button>
                </form>
            }
        </div>
    </div>
</div>
